{
  "slug": "api-doc-generator",
  "name": "Api Doc Generator",
  "domain": "Developer / API",
  "target_user": "Domain operator, business owner, analyst, or team member who needs this workflow executed reliably.",
  "core_job": "Code/OpenAPI/schema → publishable developer documentation",
  "deep_features": [
    "OpenAPI import",
    "endpoint grouping",
    "auth examples",
    "SDK snippets",
    "changelog",
    "error catalog",
    "try-it console",
    "version diff",
    "Postman/Insomnia export"
  ],
  "input_schema": [
    {
      "key": "code",
      "label": "Code",
      "type": "text",
      "required": true,
      "help": "Affects input: Code.",
      "affects": [
        "prompt",
        "workflow"
      ],
      "default": ""
