    {
      "key": "openapi",
      "label": "OpenAPI",
      "type": "text",
      "required": true,
      "help": "Affects input: OpenAPI.",
      "affects": [
        "prompt",
        "workflow"
      ],
      "default": ""
    },
    {
      "key": "schema",
      "label": "schema",
      "type": "select",
      "required": true,
      "help": "Affects input: schema.",
      "affects": [
        "prompt",
        "workflow"
      ],
      "default": ""
    },
    {
      "key": "work_brief",
      "label": "Work brief / source text / URL / instructions",
      "type": "textarea",
      "required": true,
      "default": "",
      "help": "Paste the material, URL, description, or instruction needed for this project.",
